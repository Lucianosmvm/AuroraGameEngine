<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Aurora.Editor.Views"
        xmlns:vm="clr-namespace:Aurora.Editor.ViewModels"
        x:Class="Aurora.Editor.Views.MainWindow"
        Title="{Binding Title}"
        Width="1400" Height="850"
        WindowStartupLocation="CenterScreen">

  <Window.DataTemplates>
    <!-- Editores de propriedades escalares -->
    <DataTemplate DataType="{x:Type vm:NumberPropertyViewModel}">
      <Grid ColumnDefinitions="90,*" Margin="0,2">
        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>
        <TextBox Grid.Column="1" Text="{Binding Text}" FontSize="12" Padding="6,4"/>
      </Grid>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:TextPropertyViewModel}">
      <Grid ColumnDefinitions="90,*" Margin="0,2">
        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>
        <TextBox Grid.Column="1" Text="{Binding Value}" FontSize="12" Padding="6,4"/>
      </Grid>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:BoolPropertyViewModel}">
      <CheckBox Content="{Binding Name}" IsChecked="{Binding Value}" Margin="0,2" FontSize="12"/>
    </DataTemplate>

    <!-- Animator: campos básicos + lista de clipes -->
    <DataTemplate DataType="{x:Type vm:AnimatorViewModel}">
      <Panel Margin="0,0,0,6">
        <Expander Header="Animator" IsExpanded="True" HorizontalAlignment="Stretch">
          <StackPanel Margin="6,4" Spacing="4">
            <ItemsControl ItemsSource="{Binding Properties}" Margin="0,0,0,4"/>
            <Border BorderThickness="0,1,0,0" BorderBrush="#3A3860"
                    Margin="0,2,0,2" Padding="0,4,0,0">
              <TextBlock Text="CLIPES" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
            </Border>
            <ItemsControl ItemsSource="{Binding Clips}"/>
            <Button Content="+ Clipe" Command="{Binding AddClipCommand}"
                    FontSize="12" HorizontalAlignment="Stretch" Margin="0,2"/>
          </StackPanel>
        </Expander>
        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                Content="✕" FontSize="10" Padding="5,1" Margin="0,3,4,0"
                Command="{Binding RemoveCommand}"
                IsVisible="{Binding RemoveCommand, Converter={x:Static ObjectConverters.IsNotNull}}"
                Background="Transparent" Foreground="#FF6B6B" BorderThickness="0"/>
      </Panel>
    </DataTemplate>

    <!-- AnimationClip: uma linha por clipe -->
    <DataTemplate DataType="{x:Type vm:AnimationClipViewModel}">
      <Border Background="#1A1830" CornerRadius="4" Margin="0,2" Padding="6,5">
        <StackPanel Spacing="3">
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Text="{Binding ClipName}" FontSize="12" Padding="4,3" Watermark="Nome…"/>
            <Button Grid.Column="1" Content="✕" FontSize="11" Padding="6,2" Margin="4,0,0,0"
                    Command="{Binding RemoveCommand}" Foreground="#FF6B6B"
                    Background="Transparent" BorderThickness="0"/>
          </Grid>
          <Grid ColumnDefinitions="60,*,8,35,*">
            <TextBlock Text="Frames" VerticalAlignment="Center" Opacity="0.6" FontSize="11"/>
            <TextBox Grid.Column="1" Text="{Binding FramesText}" FontSize="11" Padding="4,3"
                     Watermark="0, 1, 2…"/>
            <TextBlock Grid.Column="3" Text="Dur" VerticalAlignment="Center"
                       Opacity="0.6" FontSize="11"/>
            <TextBox Grid.Column="4" Text="{Binding FrameDurationText}" FontSize="11" Padding="4,3"/>
          </Grid>
          <CheckBox Content="Loop" IsChecked="{Binding Loop}" FontSize="11"/>
        </StackPanel>
      </Border>
    </DataTemplate>

    <!-- Componente genérico (Transform, SpriteRenderer, Tilemap, Collider…) -->
    <!-- IMPORTANTE: deve vir depois dos templates específicos (AnimatorViewModel, EventTriggerViewModel)
         pois no Avalonia o primeiro DataTemplate que bate vence e esses herdam de ComponentViewModel. -->
    <DataTemplate DataType="{x:Type vm:ComponentViewModel}">
      <Panel Margin="0,0,0,6">
        <Expander Header="{Binding Type}" IsExpanded="True" HorizontalAlignment="Stretch">
          <ItemsControl ItemsSource="{Binding Properties}" Margin="4"/>
        </Expander>
        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                Content="✕" FontSize="10" Padding="5,1" Margin="0,3,4,0"
                Command="{Binding RemoveCommand}"
                IsVisible="{Binding RemoveCommand, Converter={x:Static ObjectConverters.IsNotNull}}"
                Background="Transparent" Foreground="#FF6B6B" BorderThickness="0"/>
      </Panel>
    </DataTemplate>

    <!-- EventTrigger: editor completo de gatilho + lista de ações -->
    <DataTemplate DataType="{x:Type vm:EventTriggerViewModel}">
      <Panel Margin="0,0,0,6">
      <Expander Header="EventTrigger" IsExpanded="True"
                HorizontalAlignment="Stretch">
        <StackPanel Margin="6,4" Spacing="4">

          <!-- Tipo de gatilho -->
          <Grid ColumnDefinitions="90,*">
            <TextBlock Text="Trigger" VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding TriggerTypes}"
                      SelectedItem="{Binding TriggerType}" FontSize="12"/>
          </Grid>
          <TextBlock Text="{Binding TriggerDescription}" FontSize="11" FontStyle="Italic"
                     Opacity="0.5" Margin="0,-2,0,2"/>

          <!-- Once -->
          <CheckBox Content="Once (dispara uma vez)" IsChecked="{Binding Once}" FontSize="12"/>

          <!-- Radius — só PlayerTouch -->
          <Grid ColumnDefinitions="90,*" IsVisible="{Binding ShowRadius}">
            <TextBlock Text="Radius" VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>
            <TextBox Grid.Column="1" Text="{Binding RadiusText}" FontSize="12" Padding="6,4"/>
          </Grid>

          <!-- Switch — só SwitchOn -->
          <Grid ColumnDefinitions="90,*" IsVisible="{Binding ShowSwitch}">
            <TextBlock Text="Switch" VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>
            <TextBox Grid.Column="1" Text="{Binding SwitchName}" FontSize="12" Padding="6,4"/>
          </Grid>

          <!-- Key — só KeyPress -->
          <Grid ColumnDefinitions="90,*" IsVisible="{Binding ShowKey}">
            <TextBlock Text="Tecla" VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>
            <TextBox Grid.Column="1" Text="{Binding Key}" FontSize="12" Padding="6,4"
                     Watermark="Space, E, Enter…"/>
          </Grid>

          <!-- Interval — só Timer -->
          <Grid ColumnDefinitions="90,*" IsVisible="{Binding ShowInterval}">
            <TextBlock Text="Intervalo (s)" VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>
            <TextBox Grid.Column="1" Text="{Binding IntervalText}" FontSize="12" Padding="6,4"/>
          </Grid>

          <!-- VariableCompare: variável op valor -->
          <StackPanel IsVisible="{Binding ShowCompare}" Spacing="4">
            <Grid ColumnDefinitions="90,*">
              <TextBlock Text="Variável" VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>
              <TextBox Grid.Column="1" Text="{Binding Variable}" FontSize="12" Padding="6,4"
                       Watermark="Gold, Life…"/>
            </Grid>
            <Grid ColumnDefinitions="90,100,*">
              <TextBlock Text="Condição" VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>
              <ComboBox Grid.Column="1" ItemsSource="{Binding CompareOps}"
                        SelectedItem="{Binding CompareOp}" FontSize="12" Margin="0,0,4,0"/>
              <TextBox Grid.Column="2" Text="{Binding CompareValueText}" FontSize="12" Padding="6,4"/>
            </Grid>
          </StackPanel>

          <!-- Separador de ações -->
          <Border BorderThickness="0,1,0,0" BorderBrush="#3A3860"
                  Margin="0,4,0,2" Padding="0,4,0,0">
            <TextBlock Text="AÇÕES" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
          </Border>

          <ItemsControl ItemsSource="{Binding Actions}"/>

          <Button Content="+ Adicionar Ação" Command="{Binding AddActionCommand}"
                  FontSize="12" HorizontalAlignment="Stretch" Margin="0,2"/>
        </StackPanel>
      </Expander>
      <Button HorizontalAlignment="Right" VerticalAlignment="Top"
              Content="✕" FontSize="10" Padding="5,1" Margin="0,3,4,0"
              Command="{Binding RemoveCommand}"
              IsVisible="{Binding RemoveCommand, Converter={x:Static ObjectConverters.IsNotNull}}"
              Background="Transparent" Foreground="#FF6B6B" BorderThickness="0"/>
      </Panel>
    </DataTemplate>

    <!-- Uma ação dentro de EventTrigger -->
    <DataTemplate DataType="{x:Type vm:EventActionViewModel}">
      <Border Background="#1A1830" CornerRadius="4" Margin="0,2" Padding="6,5">
        <StackPanel Spacing="3">

          <!-- Tipo + botão remover -->
          <Grid ColumnDefinitions="*,Auto">
            <ComboBox ItemsSource="{Binding ActionTypes}"
                      SelectedItem="{Binding ActionType}" FontSize="12"/>
            <Button Grid.Column="1" Content="✕" FontSize="11" Padding="6,2" Margin="4,0,0,0"
                    Command="{Binding RemoveCommand}" Foreground="#FF6B6B"
                    Background="Transparent" BorderThickness="0"/>
          </Grid>

          <!-- Nome (variável, entidade, arquivo, falante) -->
          <Grid ColumnDefinitions="65,*" IsVisible="{Binding ShowName}">
            <TextBlock Text="{Binding NameLabel}" VerticalAlignment="Center"
                       Opacity="0.6" FontSize="11"/>
            <TextBox Grid.Column="1" Text="{Binding Name}" FontSize="11" Padding="4,3"/>
          </Grid>

          <!-- Op: Set / Add (SetVariable) -->
          <Grid ColumnDefinitions="65,*" IsVisible="{Binding ShowOp}">
            <TextBlock Text="Op" VerticalAlignment="Center" Opacity="0.6" FontSize="11"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding OpTypes}"
                      SelectedItem="{Binding Op}" FontSize="11"/>
          </Grid>

          <!-- Valor numérico -->
          <Grid ColumnDefinitions="65,*" IsVisible="{Binding ShowValue}">
            <TextBlock Text="{Binding ValueLabel}" VerticalAlignment="Center"
                       Opacity="0.6" FontSize="11"/>
            <TextBox Grid.Column="1" Text="{Binding ValueText}" FontSize="11" Padding="4,3"/>
          </Grid>

          <!-- On / Loop (SetSwitch, PlayMusic) -->
          <CheckBox Content="{Binding OnLabel}" IsChecked="{Binding On}"
                    FontSize="11" IsVisible="{Binding ShowOn}" Margin="0,1"/>

          <!-- X / Y (Teleport) -->
          <Grid ColumnDefinitions="28,*,8,28,*" IsVisible="{Binding ShowXY}">
            <TextBlock Text="X" VerticalAlignment="Center" Opacity="0.6" FontSize="11"/>
            <TextBox Grid.Column="1" Text="{Binding XText}" FontSize="11" Padding="4,3"/>
            <TextBlock Grid.Column="3" Text="Y" VerticalAlignment="Center"
                       Opacity="0.6" FontSize="11"/>
            <TextBox Grid.Column="4" Text="{Binding YText}" FontSize="11" Padding="4,3"/>
          </Grid>

          <!-- Segundos (Wait) -->
          <Grid ColumnDefinitions="65,*" IsVisible="{Binding ShowSeconds}">
            <TextBlock Text="Segundos" VerticalAlignment="Center" Opacity="0.6" FontSize="11"/>
            <TextBox Grid.Column="1" Text="{Binding SecondsText}" FontSize="11" Padding="4,3"/>
          </Grid>

          <!-- Texto / Clipe (ShowMessage, ShowChoice, PlayAnimation) -->
          <Grid ColumnDefinitions="65,*" IsVisible="{Binding ShowText}">
            <TextBlock Text="{Binding TextLabel}" VerticalAlignment="Center" Opacity="0.6" FontSize="11"/>
            <TextBox Grid.Column="1" Text="{Binding Text}" FontSize="11" Padding="4,3"
                     TextWrapping="Wrap"/>
          </Grid>

          <!-- Opções de ShowChoice -->
          <StackPanel IsVisible="{Binding ShowOptions}" Margin="0,4,0,0">
            <TextBlock Text="Opções:" FontSize="10" Opacity="0.6" Margin="0,0,0,2"/>
            <ItemsControl ItemsSource="{Binding Options}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="*,76,Auto" Margin="0,1" ColumnSpacing="4">
                    <TextBox Text="{Binding Text}" FontSize="11" Padding="4,2"
                             Watermark="Texto da opção…"/>
                    <TextBox Grid.Column="1" Text="{Binding SwitchName}" FontSize="11"
                             Padding="4,2" Watermark="Switch"/>
                    <Button Grid.Column="2" Content="✕" FontSize="10" Padding="4,2"
                            Command="{Binding RemoveCommand}" Foreground="#FF6B6B"
                            Background="Transparent" BorderThickness="0"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="+ Opção" Command="{Binding AddOptionCommand}"
                    FontSize="11" Margin="0,2"/>
          </StackPanel>

        </StackPanel>
      </Border>
    </DataTemplate>
  </Window.DataTemplates>

  <DockPanel>
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_Arquivo">
        <MenuItem Header="_Nova Cena…" Click="OnNewScene" InputGesture="Ctrl+N"/>
        <MenuItem Header="_Abrir Cena…" Click="OnOpenScene" InputGesture="Ctrl+O"/>
        <MenuItem Header="_Salvar" Click="OnSaveScene" InputGesture="Ctrl+S" IsEnabled="{Binding HasDocument}"/>
        <MenuItem Header="Salvar _Como…" Click="OnSaveSceneAs" InputGesture="Ctrl+Shift+S" IsEnabled="{Binding HasDocument}"/>
        <Separator/>
        <MenuItem Header="Sai_r" Click="OnExit"/>
      </MenuItem>
      <MenuItem Header="_Editar">
        <MenuItem Header="_Desfazer" Click="OnUndo" InputGesture="Ctrl+Z" IsEnabled="{Binding CanUndo}"/>
        <MenuItem Header="_Refazer" Click="OnRedo" InputGesture="Ctrl+Y" IsEnabled="{Binding CanRedo}"/>
      </MenuItem>
    </Menu>

    <!-- Toolbar de execução -->
    <Border DockPanel.Dock="Top" Background="#16142A" Padding="8,5"
            BorderBrush="#2A2740" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="▶  Play" Click="OnPlay"
                IsEnabled="{Binding CanPlay}"
                FontSize="13" FontWeight="SemiBold" Padding="14,5"
                Background="#1B5E20" Foreground="White"/>
        <TextBlock Text="Projeto não configurado — preencha o campo PROJETO no inspector."
                   VerticalAlignment="Center" FontSize="11" Opacity="0.5"
                   IsVisible="{Binding !CanPlay}"/>
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" Background="#1E1C30" Padding="8,4">
      <TextBlock Text="{Binding Status}" FontSize="12" Opacity="0.8"/>
    </Border>

    <Grid ColumnDefinitions="230,4,*,4,330">

      <!-- Assets + Hierarquia -->
      <Grid Grid.Column="0" RowDefinitions="*,4,*">

        <DockPanel Grid.Row="0">
          <DockPanel DockPanel.Dock="Top" Margin="10,8,8,8">
            <Button DockPanel.Dock="Right" Content="↻" FontSize="12" Padding="6,2"
                    Click="OnRefreshAssets" IsEnabled="{Binding HasDocument}"
                    ToolTip.Tip="Reescanear pasta de assets"/>
            <TextBlock Text="ASSETS" FontSize="11" FontWeight="Bold" Opacity="0.5"
                       VerticalAlignment="Center"/>
          </DockPanel>
          <ListBox x:Name="AssetList" ItemsSource="{Binding Assets}"
                   DoubleTapped="OnAssetDoubleTapped">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8" Background="Transparent">
                  <Border Width="32" Height="32" Background="#141220" CornerRadius="3">
                    <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="2"
                           RenderOptions.BitmapInterpolationMode="None"/>
                  </Border>
                  <TextBlock Text="{Binding RelativePath}" VerticalAlignment="Center"
                             FontSize="12" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>

        <GridSplitter Grid.Row="1" Background="#2A2740"/>

        <DockPanel Grid.Row="2">
          <TextBlock DockPanel.Dock="Top" Text="HIERARQUIA" Margin="10,8" FontSize="11"
                     FontWeight="Bold" Opacity="0.5"/>
          <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="8" Spacing="6">
            <Button Content="+ Nova" Click="OnCreateEntity" FontSize="12"
                    IsEnabled="{Binding HasDocument}"/>
            <Button Content="+ Tilemap" Click="OnCreateTilemap" FontSize="12"
                    IsEnabled="{Binding HasDocument}"/>
            <Button Content="Excluir" Click="OnDeleteEntity" FontSize="12"
                    IsEnabled="{Binding SelectedEntity, Converter={x:Static ObjectConverters.IsNotNull}}"/>
          </StackPanel>
          <Grid RowDefinitions="*,4,Auto">
            <ListBox Grid.Row="0" ItemsSource="{Binding Entities}"
                     SelectedItem="{Binding SelectedEntity}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="#2D1E50" CornerRadius="3" Padding="5,2"
                            Margin="6,0,0,0" VerticalAlignment="Center"
                            IsVisible="{Binding HasEventTrigger}">
                      <TextBlock Text="{Binding TriggerTypeLabel}" FontSize="10"
                                 Foreground="#B89FFF" FontWeight="SemiBold"/>
                    </Border>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <GridSplitter Grid.Row="1" Background="#2A2740"
                          IsVisible="{Binding HasEventEntities}"/>

            <!-- Painel EVENTOS: lista rápida de entidades com EventTrigger -->
            <Border Grid.Row="2" Background="#100D1A"
                    IsVisible="{Binding HasEventEntities}">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="EVENTOS" FontSize="10" FontWeight="Bold"
                           Opacity="0.5" Margin="10,6,8,3"/>
                <ListBox ItemsSource="{Binding EventEntities}"
                         SelectedItem="{Binding SelectedEntity}"
                         Background="Transparent" MaxHeight="120">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="#2D1E50" CornerRadius="3" Padding="4,1"
                                Margin="4,0,0,0" VerticalAlignment="Center">
                          <TextBlock Text="{Binding TriggerTypeLabel}" FontSize="10"
                                     Foreground="#B89FFF"/>
                        </Border>
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </DockPanel>
            </Border>
          </Grid>
        </DockPanel>
      </Grid>

      <GridSplitter Grid.Column="1" Background="#2A2740"/>

      <!-- Cena + paleta de tiles -->
      <Grid Grid.Column="2" RowDefinitions="*,Auto">
        <views:SceneCanvas x:Name="Scene" Grid.Row="0" DataContext="{Binding}"/>
        <Border Grid.Row="1" Background="#1E1C30" Padding="8,6"
                IsVisible="{Binding HasTilePalette}">
          <ListBox ItemsSource="{Binding PaletteTiles}"
                   SelectedItem="{Binding SelectedTileBrush}"
                   Background="Transparent" MaxHeight="96">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Width="36" Height="36" Background="#141220" CornerRadius="3"
                        ToolTip.Tip="{Binding Index}">
                  <Panel>
                    <Image Source="{Binding Image}" Stretch="Uniform" Margin="2"
                           RenderOptions.BitmapInterpolationMode="None"/>
                    <TextBlock Text="{Binding Label}" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Panel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </Grid>

      <GridSplitter Grid.Column="3" Background="#2A2740"/>

      <!-- Inspector -->
      <DockPanel Grid.Column="4">
        <TextBlock DockPanel.Dock="Top" Text="INSPECTOR" Margin="10,8" FontSize="11"
                   FontWeight="Bold" Opacity="0.5"/>

        <!-- Assets Root — visível quando há uma cena aberta -->
        <Border DockPanel.Dock="Top" Background="#1A1830" Padding="8,6" Margin="0,0,0,2"
                IsVisible="{Binding HasDocument}">
          <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
            <TextBlock Text="ASSETS ROOT" FontSize="10" FontWeight="Bold" Opacity="0.5"
                       Grid.ColumnSpan="2" Margin="0,0,0,3"/>
            <TextBlock Grid.Row="1" Text="{Binding AssetsRootDisplay}" FontSize="11"
                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                       ToolTip.Tip="{Binding AssetsRootDisplay}"/>
            <Button Grid.Row="1" Grid.Column="1" Content="Alterar…" FontSize="11"
                    Padding="6,2" Margin="4,0,0,0" Click="OnChangeAssetsRoot"/>
          </Grid>
        </Border>

        <!-- Projeto: caminho do executável/csproj para o botão Play -->
        <Border DockPanel.Dock="Top" Background="#1A1830" Padding="8,6" Margin="0,0,0,4"
                IsVisible="{Binding HasDocument}">
          <StackPanel Spacing="4">
            <TextBlock Text="PROJETO" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Text="{Binding GameProjectPath}" FontSize="11" Padding="4,3"
                       Watermark=".csproj, pasta ou .exe do jogo…" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Content="…" FontSize="11" Padding="6,2" Margin="4,0,0,0"
                      Click="OnBrowseGameProject"/>
            </Grid>
            <TextBlock FontSize="10" Opacity="0.45" TextWrapping="Wrap">
              No Main() do jogo: game.ParseArgs(args); e em OnLoad(): LoadScene(BootScene ?? "default.json");
            </TextBlock>
          </StackPanel>
        </Border>
        <ScrollViewer>
          <StackPanel Margin="10,0,10,10" DataContext="{Binding SelectedEntity}"
                      IsVisible="{Binding Converter={x:Static ObjectConverters.IsNotNull}}">
            <Grid ColumnDefinitions="90,*" Margin="0,0,0,8">
              <TextBlock Text="Nome" VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>
              <TextBox Grid.Column="1" Text="{Binding Name}" FontSize="13" Padding="6,4"/>
            </Grid>

            <ItemsControl ItemsSource="{Binding Components}"/>

            <!-- Adicionar Componente -->
            <Border BorderThickness="0,1,0,0" BorderBrush="#3A3860" Margin="0,8,0,4"/>
            <Grid ColumnDefinitions="*,Auto">
              <ComboBox ItemsSource="{Binding AvailableComponentTypes}"
                        SelectedItem="{Binding NewComponentType}" FontSize="12"/>
              <Button Grid.Column="1" Content="+ Add" FontSize="12"
                      Padding="8,4" Margin="4,0,0,0"
                      Command="{Binding AddComponentCommand}"/>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
